FORM_OCR_APP_NAME=Form OCR M1
FORM_OCR_API_V1_PREFIX=/api/v1
FORM_OCR_DATA_DIR=artifacts
FORM_OCR_TEMPLATES_PATH=config/template_registry.json
FORM_OCR_PIPELINE_VERSION=v1
FORM_OCR_RENDER_DPI=300
FORM_OCR_MAX_UPLOAD_MB=25
FORM_OCR_ANCHOR_CONFIDENCE_THRESHOLD=0.65
FORM_OCR_TEMPLATE_HIT_THRESHOLD=0.85
FORM_OCR_TEMPLATE_PARTIAL_THRESHOLD=0.50
FORM_OCR_TEMPLATE_LAYOUT_WEIGHT=0.35
FORM_OCR_TEMPLATE_ANCHOR_WEIGHT=0.45
FORM_OCR_TEMPLATE_PAGE_COUNT_WEIGHT=0.20
FORM_OCR_LINE_MIN_WIDTH_RATIO=0.08
FORM_OCR_LINE_MAX_WIDTH_RATIO=0.90
FORM_OCR_LINE_MAX_HEIGHT_RATIO=0.03
FORM_OCR_CHECKBOX_MIN_AREA=100
FORM_OCR_CHECKBOX_MAX_AREA=5000
FORM_OCR_CHECKBOX_FILL_THRESHOLD=0.30
FORM_OCR_TEXT_FILLED_INK_THRESHOLD=0.02
FORM_OCR_OCR_ENGINE=rapidocr
FORM_OCR_DEFAULT_VLM_MODEL=gpt-4o
FORM_OCR_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
